# Site URL (no trailing slash) - used for canonical URLs, OG tags, sitemap, structured data
# Set in Vercel env for production. Fallback used in dev if unset.
# Use the same host you want as canonical (apex vs www); mismatch confuses SEO + social previews.
VITE_SITE_URL=https://usmechanical.com

# Cloudflare Turnstile (human verification for contact form)
# Get your keys at https://dash.cloudflare.com → Application security → Turnstile
# Use test site key for development: 1x00000000000000000000AA
VITE_TURNSTILE_SITE_KEY=your_cloudflare_turnstile_site_key

# Cloudflare Turnstile secret key (server-side only - never prefix with VITE_)
# Use test secret key for development: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=your_cloudflare_turnstile_secret_key

# Resend (contact form email delivery)
# Get your API key at https://resend.com/api-keys
# Verify your domain at https://resend.com/domains to send from your own address
RESEND_API_KEY=re_your_resend_api_key
# Who receives contact form submissions (default: info@usmechanicalllc.com)
CONTACT_FORM_TO_EMAIL=info@usmechanicalllc.com
# From address (use "Name <onboarding@resend.dev>" for testing; use verified domain in production)
RESEND_FROM_EMAIL=US Mechanical Contact <onboarding@resend.dev>

# Upstash Redis (server-side rate limiting for /api/contact)
# Create a free Redis database at https://console.upstash.com/redis
# Copy the REST URL and REST token from the database details page.
# If unset, the API falls back to Turnstile + honeypot only (no IP rate limit).
UPSTASH_REDIS_REST_URL=https://your-db-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
